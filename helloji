<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>hey you :)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Caveat:wght@500;600;700&family=Shadows+Into+Light&display=swap" rel="stylesheet">
<style>
  :root{
    --pink-deep:#e8879c;
    --pink-mid:#f2a7b6;
    --pink-soft:#f7cdd6;
    --pink-line:#e08a9c;
    --cream:#fffdfa;
    --ink:#7a3b47;
    --ink-soft:#b8687a;
  }
  *{box-sizing:border-box;}
  html,body{
    margin:0;
    padding:0;
    height:100%;
    width:100%;
    overflow:hidden;
    font-family:'Baloo 2', sans-serif;
  }
  body{
    background:
      repeating-linear-gradient(
        135deg,
        var(--pink-deep) 0px,
        var(--pink-deep) 26px,
        var(--pink-mid) 26px,
        var(--pink-mid) 52px
      );
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .stage{
    position:relative;
    width:100%;
    height:100%;
    max-width:900px;
    max-height:560px;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  /* decorative pink corner blobs peeking from behind the card */
  .corner-blob{
    position:absolute;
    border-radius:50%;
    background:var(--pink-deep);
    z-index:1;
  }
  .corner-blob.br{
    width:260px;height:260px;
    right:-60px; bottom:-90px;
  }
  .corner-blob.tl{
    width:140px;height:140px;
    left:-40px; top:-40px;
    background:var(--pink-mid);
  }
  .card{
    position:relative;
    z-index:2;
    width:94%;
    height:88%;
    background:
      linear-gradient(0deg, rgba(220,150,165,0.10) 1px, transparent 1px),
      linear-gradient(90deg, rgba(220,150,165,0.10) 1px, transparent 1px),
      var(--cream);
    background-size:24px 24px, 24px 24px, cover;
    border-radius:58% 42% 38% 62% / 55% 35% 65% 45%;
    box-shadow:0 20px 50px rgba(120,40,60,0.35);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }
  .screen{
    display:none;
    width:100%;
    height:100%;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:30px 8%;
    position:relative;
    animation:fadeIn .45s ease;
  }
  .screen.active{display:flex;}
  @keyframes fadeIn{
    from{opacity:0; transform:translateY(10px);}
    to{opacity:1; transform:translateY(0);}
  }

  h1.big{
    font-family:'Baloo 2', sans-serif;
    font-weight:800;
    color:var(--pink-deep);
    -webkit-text-stroke:1.5px var(--ink);
    font-size:clamp(2.2rem, 6vw, 3.4rem);
    margin:0 0 6px 0;
    letter-spacing:1px;
  }
  p.hand{
    font-family:'Shadows Into Light', cursive;
    color:var(--ink);
    font-size:clamp(1.3rem, 3.2vw, 1.9rem);
    margin:2px 0;
  }
  p.hand.soft{
    color:var(--ink-soft);
    font-size:clamp(1.1rem, 2.6vw, 1.5rem);
  }

  .btn-row{
    display:flex;
    gap:22px;
    margin-top:26px;
    flex-wrap:wrap;
    justify-content:center;
  }
  .btn{
    font-family:'Caveat', cursive;
    font-weight:700;
    font-size:1.6rem;
    color:var(--cream);
    background:var(--pink-deep);
    border:none;
    padding:10px 34px;
    border-radius:40px;
    cursor:pointer;
    text-decoration:underline;
    text-underline-offset:4px;
    box-shadow:0 6px 0 var(--ink-soft);
    transition:transform .12s ease, box-shadow .12s ease;
  }
  .btn:hover{transform:translateY(2px); box-shadow:0 4px 0 var(--ink-soft);}
  .btn:active{transform:translateY(6px); box-shadow:0 0 0 var(--ink-soft);}

  /* ---------- cat mascot, drawn purely in CSS/SVG (no external images) ---------- */
  .cat-wrap{ position:relative; width:190px; height:190px; margin:6px 0; }
  .cat-wrap svg{ width:100%; height:100%; overflow:visible; }

  .deco-heart{
    position:absolute;
    font-size:1.4rem;
    color:var(--pink-deep);
    opacity:.85;
  }
  .rose{
    font-size:2.6rem;
    position:absolute;
    right:-6px;
    top:-8px;
    transform:rotate(15deg);
  }
  .sunflower{
    position:absolute;
    font-size:1.8rem;
    right:14px;
    bottom:14px;
  }
  .kiss-mark{
    position:absolute;
    font-size:1.1rem;
    color:#c65b74;
  }

  .next-btn{
    margin-top:24px;
  }
  .camera-icon{
    position:absolute;
    bottom:14px;
    right:20px;
    font-size:1.3rem;
    color:var(--ink-soft);
  }

  /* envelope screen */
  .envelope{
    width:220px;
    height:150px;
    cursor:pointer;
    position:relative;
  }
  .envelope svg{width:100%; height:100%;}

  /* letter screen */
  .letter-wrap{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:26px;
    flex-wrap:wrap;
    max-width:100%;
  }
  .letter-note{
    background:var(--cream);
    border:1px solid var(--pink-soft);
    border-radius:14px;
    padding:18px 22px;
    max-width:280px;
    box-shadow:0 8px 18px rgba(150,80,95,.18);
    position:relative;
  }
  .letter-note::before{
    content:"";
    position:absolute;
    top:-26px; left:50%;
    transform:translateX(-50%) rotate(-8deg);
    width:60px; height:26px;
    background:var(--pink-soft);
    border-radius:4px;
    box-shadow:0 3px 6px rgba(150,80,95,.25);
  }
  .letter-note p{
    font-family:'Shadows Into Light', cursive;
    color:var(--ink);
    font-size:1.15rem;
    margin:0;
    line-height:1.5;
  }
  .letter-note .glow{
    color:#5aa06b;
    font-weight:600;
  }
  .hearts-photos{
    display:flex;
    gap:10px;
  }
  .heart-frame{
    width:100px;
    height:100px;
    position:relative;
  }
  .heart-frame svg{ width:100%; height:100%; }
  .teddy{
    position:absolute;
    left:-18px;
    top:-24px;
    font-size:2.2rem;
    transform:rotate(-14deg);
  }
  .ribbon-tag{
    position:absolute;
    top:-30px;
    left:50%;
    transform:translateX(-50%);
    font-size:1.6rem;
  }

  .go-back-wrap{margin-top:22px;}
</style>
</head>
<body>
<div class="stage">
  <div class="corner-blob br"></div>
  <div class="corner-blob tl"></div>
  <div class="card">

    <!-- SCREEN 1 : HEY -->
    <div class="screen active" id="screen-hey">
      <h1 class="big">HEY!!</h1>
      <p class="hand">I made something for you</p>
      <p class="hand soft">Do you want to see?</p>

      <div class="cat-wrap">
        <span class="rose">🌹</span>
        <svg viewBox="0 0 200 200">
          <!-- ears -->
          <path d="M40 70 Q20 20 70 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <path d="M160 70 Q180 20 130 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <path d="M50 62 Q42 35 68 50 Z" fill="#f4b6c2"/>
          <path d="M150 62 Q158 35 132 50 Z" fill="#f4b6c2"/>
          <!-- head -->
          <ellipse cx="100" cy="115" rx="62" ry="55" fill="#faf3ec" stroke="#d8bfae" stroke-width="3"/>
          <!-- cheeks -->
          <ellipse cx="65" cy="130" rx="14" ry="9" fill="#f7c6ce" opacity="0.8"/>
          <ellipse cx="135" cy="130" rx="14" ry="9" fill="#f7c6ce" opacity="0.8"/>
          <!-- eyes -->
          <ellipse cx="78" cy="112" rx="8" ry="10" fill="#3a2a2a"/>
          <ellipse cx="122" cy="112" rx="8" ry="10" fill="#3a2a2a"/>
          <circle cx="81" cy="108" r="2.4" fill="#fff"/>
          <circle cx="125" cy="108" r="2.4" fill="#fff"/>
          <!-- nose + mouth -->
          <path d="M96 128 L104 128 L100 134 Z" fill="#e0879a"/>
          <path d="M100 134 Q100 140 92 141" stroke="#3a2a2a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <path d="M100 134 Q100 140 108 141" stroke="#3a2a2a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <!-- whiskers -->
          <line x1="30" y1="120" x2="58" y2="118" stroke="#d8bfae" stroke-width="2"/>
          <line x1="30" y1="132" x2="58" y2="130" stroke="#d8bfae" stroke-width="2"/>
          <line x1="170" y1="120" x2="142" y2="118" stroke="#d8bfae" stroke-width="2"/>
          <line x1="170" y1="132" x2="142" y2="130" stroke="#d8bfae" stroke-width="2"/>
        </svg>
      </div>

      <div class="btn-row">
        <button class="btn" onclick="show('screen-yes')">Yes</button>
        <button class="btn" onclick="show('screen-no')">No</button>
      </div>
    </div>

    <!-- SCREEN 2 : NO -> HOW DARE YOU -->
    <div class="screen" id="screen-no">
      <div class="cat-wrap" style="width:150px;height:150px;">
        <svg viewBox="0 0 200 200">
          <path d="M40 70 Q20 20 70 45 Z" fill="#ffffff" stroke="#e3d8d2" stroke-width="3"/>
          <path d="M160 70 Q180 20 130 45 Z" fill="#ffffff" stroke="#e3d8d2" stroke-width="3"/>
          <ellipse cx="100" cy="115" rx="62" ry="55" fill="#ffffff" stroke="#e3d8d2" stroke-width="3"/>
          <!-- shocked eyes -->
          <circle cx="78" cy="112" r="10" fill="#3a2a2a"/>
          <circle cx="122" cy="112" r="10" fill="#3a2a2a"/>
          <circle cx="82" cy="107" r="2.6" fill="#fff"/>
          <circle cx="126" cy="107" r="2.6" fill="#fff"/>
          <!-- shocked mouth (small o) -->
          <ellipse cx="100" cy="135" rx="6" ry="8" fill="#3a2a2a"/>
          <!-- little exclamation over head -->
          <text x="130" y="55" font-size="26" fill="#e8879c">✳</text>
        </svg>
      </div>
      <h1 class="big" style="font-size:clamp(1.8rem,5vw,2.8rem);">HOW DARE YOU</h1>
      <div class="go-back-wrap">
        <button class="btn" onclick="show('screen-hey')">Go back</button>
      </div>
    </div>

    <!-- SCREEN 3 : YES -> good girl -->
    <div class="screen" id="screen-yes">
      <div class="cat-wrap">
        <svg viewBox="0 0 200 200">
          <path d="M40 70 Q20 20 70 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <path d="M160 70 Q180 20 130 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <path d="M50 62 Q42 35 68 50 Z" fill="#f4b6c2"/>
          <path d="M150 62 Q158 35 132 50 Z" fill="#f4b6c2"/>
          <ellipse cx="100" cy="115" rx="62" ry="55" fill="#faf3ec" stroke="#d8bfae" stroke-width="3"/>
          <ellipse cx="65" cy="130" rx="14" ry="9" fill="#f7c6ce" opacity="0.8"/>
          <ellipse cx="135" cy="130" rx="14" ry="9" fill="#f7c6ce" opacity="0.8"/>
          <!-- happy closed eyes -->
          <path d="M70 110 Q78 100 86 110" stroke="#3a2a2a" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M114 110 Q122 100 130 110" stroke="#3a2a2a" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M96 128 L104 128 L100 134 Z" fill="#e0879a"/>
          <path d="M88 136 Q100 148 112 136" stroke="#3a2a2a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        </svg>
        <span class="kiss-mark" style="top:6px; left:14px;">💋</span>
        <span class="kiss-mark" style="top:36px; right:10px;">💋</span>
        <span class="kiss-mark" style="bottom:40px; left:2px;">💋</span>
      </div>
      <p class="hand" style="font-weight:600;">That's a good Gurlll</p>
      <span class="sunflower">🌻</span>
      <div class="btn-row">
        <button class="btn" onclick="show('screen-thanks')">Click</button>
      </div>
    </div>

    <!-- SCREEN 4 : THANK YOU JI -->
    <div class="screen" id="screen-thanks">
      <div class="cat-wrap" style="width:170px;height:170px;">
        <svg viewBox="0 0 200 200">
          <!-- party hat -->
          <path d="M100 10 L130 60 L70 60 Z" fill="#e8879c" stroke="#c65b74" stroke-width="2"/>
          <circle cx="100" cy="10" r="6" fill="#f7cdd6"/>
          <path d="M40 70 Q20 20 70 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <path d="M160 70 Q180 20 130 45 Z" fill="#f2e9e1" stroke="#d8bfae" stroke-width="3"/>
          <ellipse cx="100" cy="118" rx="62" ry="55" fill="#faf3ec" stroke="#d8bfae" stroke-width="3"/>
          <path d="M70 112 Q78 102 86 112" stroke="#3a2a2a" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M114 112 Q122 102 130 112" stroke="#3a2a2a" stroke-width="3" fill="none" stroke-linecap="round"/>
          <ellipse cx="100" cy="140" rx="18" ry="10" fill="#3a2a2a"/>
          <ellipse cx="100" cy="138" rx="13" ry="6" fill="#fff"/>
        </svg>
      </div>
      <h1 class="big" style="font-size:clamp(1.9rem,5.5vw,3rem);">THANK YOU JI ❤️</h1>
      <p class="hand soft">You are my favorite notification &lt;3</p>
      <p class="hand soft">Stay cute, stay happy</p>
      <button class="btn next-btn" onclick="show('screen-envelope')">Next</button>
    </div>

    <!-- SCREEN 5 : ENVELOPE -->
    <div class="screen" id="screen-envelope">
      <div class="envelope" onclick="show('screen-letter')">
        <svg viewBox="0 0 220 150">
          <rect x="4" y="4" width="212" height="142" rx="6" fill="#f7cdd6" stroke="#e08a9c" stroke-width="2"/>
          <path d="M4 6 L110 90 L216 6" fill="none" stroke="#e08a9c" stroke-width="2.5"/>
          <path d="M4 146 L84 74" stroke="#e08a9c" stroke-width="2"/>
          <path d="M216 146 L136 74" stroke="#e08a9c" stroke-width="2"/>
          <!-- ribbon -->
          <rect x="0" y="66" width="220" height="16" fill="#e8879c"/>
          <path d="M92 55 L110 74 L128 55 L120 78 L136 90 L110 82 L84 90 L100 78 Z" fill="#c65b74"/>
        </svg>
      </div>
      <p class="hand" style="margin-top:18px;">Tap here to open</p>
      <span class="deco-heart" style="bottom:12px; left:16px;">🌸</span>
      <span class="deco-heart" style="bottom:12px; right:16px;">🌸</span>
    </div>

    <!-- SCREEN 6 : LETTER -->
    <div class="screen" id="screen-letter">
      <div class="letter-wrap">
        <div class="letter-note">
          <span class="ribbon-tag">🎀</span>
          <span class="teddy">🧸</span>
          <p>You are my favorite person to talk to.<br>
             I am here for u no matter what.<br>
             If u ever feel sad, remember I'm here to listen to all things u wanna say <span class="glow">:)</span></p>
        </div>
        <div class="hearts-photos">
          <div class="heart-frame">
            <svg viewBox="0 0 100 100">
              <defs>
                <clipPath id="heartClip1" clipPathUnits="objectBoundingBox">
                  <path d="M0.48 0.84 C0.10 0.56 0.04 0.30 0.20 0.16 C0.32 0.06 0.46 0.10 0.48 0.24 C0.50 0.10 0.64 0.06 0.76 0.16 C0.92 0.30 0.86 0.56 0.48 0.84 Z"/>
                </clipPath>
              </defs>
              <image href="data:image/jpeg;base64," x="0" y="0" width="100" height="100" preserveAspectRatio="xMidYMid slice" clip-path="url(#heartClip1)"/>
              <path d="M48 84 C10 56 4 30 20 16 C32 6 46 10 48 24 C50 10 64 6 76 16 C92 30 86 56 48 84 Z" fill="none" stroke="#e8879c" stroke-width="6"/>
            </svg>
          </div>
          <div class="heart-frame">
            <svg viewBox="0 0 100 100">
              <defs>
                <clipPath id="heartClip2" clipPathUnits="objectBoundingBox">
                  <path d="M0.48 0.84 C0.10 0.56 0.04 0.30 0.20 0.16 C0.32 0.06 0.46 0.10 0.48 0.24 C0.50 0.10 0.64 0.06 0.76 0.16 C0.92 0.30 0.86 0.56 0.48 0.84 Z"/>
                </clipPath>
              </defs>
              <image href="data:image/jpeg;base64," x="0" y="0" width="100" height="100" preserveAspectRatio="xMidYMid slice" clip-path="url(#heartClip2)"/>
              <path d="M48 84 C10 56 4 30 20 16 C32 6 46 10 48 24 C50 10 64 6 76 16 C92 30 86 56 48 84 Z" fill="none" stroke="#e8879c" stroke-width="6"/>
            </svg>
          </div>
          </div>
      </div>
      <p class="hand soft" style="margin-top:18px;">You are seen, you are heard, and you are loved — no matter what.</p>
    </div>

  </div>
</div>

<script>
function show(id){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
</script>
</body>
</html>
